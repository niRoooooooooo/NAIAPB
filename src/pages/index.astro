		<!-- NAVBAR SCROLL SCRIPT & ADVANCED ANIMATIONS -->
		<script is:inline>
			// Progress bar scroll tracking
			function updateProgressBar() {
				const scrollTop = window.scrollY;
				const docHeight =
					document.documentElement.scrollHeight - window.innerHeight;
				const scrollPercent = (scrollTop / docHeight) * 100;
				document.body.style.setProperty(
					"--scroll-progress",
					scrollPercent + "%",
				);
			}
			window.addEventListener("scroll", updateProgressBar);

			// Update progress bar style
			const style = document.createElement("style");
			style.textContent = `body::before { width: var(--scroll-progress, 0%); }`;
			document.head.appendChild(style);

			const header = document.querySelector("header");

			function updateNavbar() {
				if (window.scrollY > 50) {
					header.classList.add("solid");
					header.classList.remove("transparent");
				} else {
					header.classList.add("transparent");
					header.classList.remove("solid");
				}
			}

			window.addEventListener("scroll", updateNavbar);
			updateNavbar();

			// Typing effect for hero section
			(function () {
				const messages = [
					"Learn. Build. Grow together.",
					"AI for all.",
					"Be the change to the society.",
				];

				const TYPING_SPEED = 60;
				const DELETING_SPEED = 30;
				const HOLD_AFTER = 2200;
				const HOLD_BEFORE = 400;

				let msgIndex = 0;
				let charIndex = 0;
				let isDeleting = false;

				const typingEl = document.querySelector(".typing-text");
				if (!typingEl) return;

				let textNode = document.createTextNode("");
				const cursorSpan = typingEl.querySelector(".cursor");
				typingEl.innerHTML = "";
				typingEl.appendChild(textNode);
				if (cursorSpan) typingEl.appendChild(cursorSpan);

				function tick() {
					const current = messages[msgIndex];

					if (!isDeleting) {
						charIndex++;
						textNode.nodeValue = current.slice(0, charIndex);

						if (charIndex === current.length) {
							isDeleting = true;
							setTimeout(tick, HOLD_AFTER);
							return;
						}
						setTimeout(tick, TYPING_SPEED);
					} else {
						charIndex--;
						textNode.nodeValue = current.slice(0, charIndex);

						if (charIndex === 0) {
							isDeleting = false;
							msgIndex = (msgIndex + 1) % messages.length;
							setTimeout(tick, HOLD_BEFORE);
							return;
						}
						setTimeout(tick, DELETING_SPEED);
					}
				}

				setTimeout(tick, 800);
			})();

			// Scroll reveal animations
			const observer = new IntersectionObserver(
				(entries) =>
					entries.forEach((e) => {
						if (e.isIntersecting) {
							e.target.classList.add("is-visible");
							observer.unobserve(e.target);
						}
					}),
				{ threshold: 0.12 },
			);
			document
				.querySelectorAll("[data-reveal]")
				.forEach((el) => observer.observe(el));

			// Magnetic button effect
			document.querySelectorAll(".btn").forEach((btn) => {
				btn.addEventListener("mousemove", (e) => {
					const rect = btn.getBoundingClientRect();
					const x = e.clientX - rect.left - rect.width / 2;
					const y = e.clientY - rect.top - rect.height / 2;

					const distance = Math.sqrt(x * x + y * y);
					if (distance < 100) {
						const angle = Math.atan2(y, x);
						const pull = (100 - distance) / 100;
						btn.style.transform = `translate(${Math.cos(angle) * pull * 8}px, ${Math.sin(angle) * pull * 8}px)`;
					}
				});

				btn.addEventListener("mouseleave", () => {
					btn.style.transform = "";
				});
			});

			// 3D card tilt effect
			document
				.querySelectorAll(".workshop-card, .partner-card")
				.forEach((card) => {
					card.addEventListener("mousemove", (e) => {
						const rect = card.getBoundingClientRect();
						const x = e.clientX - rect.left;
						const y = e.clientY - rect.top;

						const centerX = rect.width / 2;
						const centerY = rect.height / 2;

						const rotateX = (y - centerY) / 20;
						const rotateY = (centerX - x) / 20;

						card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
						card.style.boxShadow = `0 20px 40px rgba(0,0,0,0.2)`;
					});

					card.addEventListener("mouseleave", () => {
						card.style.transform = "";
						card.style.boxShadow = "";
					});
				});

			// X-Ray Cursor Reveal Effect
			document
				.querySelectorAll(".x-ray-container")
				.forEach((container) => {
					const reveal = container.querySelector(".x-ray-reveal");
					if (!reveal) return;

					container.addEventListener("mousemove", (e) => {
						const rect = container.getBoundingClientRect();
						const x = e.clientX - rect.left;
						const y = e.clientY - rect.top;

						reveal.style.clipPath = `circle(60px at ${x}px ${y}px)`;
					});

					container.addEventListener("mouseleave", () => {
						reveal.style.clipPath = "circle(0px at 50% 50%)";
					});
				});

			// Magnetic Canvas Attraction - Elements drift toward cursor
			document.querySelectorAll("[data-magnetic]").forEach((el) => {
				el.addEventListener("mousemove", (e) => {
					const rect = el.getBoundingClientRect();
					const centerX = rect.left + rect.width / 2;
					const centerY = rect.top + rect.height / 2;

					const angle = Math.atan2(
						e.clientY - centerY,
						e.clientX - centerX,
					);
					const distance = Math.hypot(
						e.clientX - centerX,
						e.clientY - centerY,
					);
					const pull = Math.max(
						0,
						Math.min(1, (200 - distance) / 200),
					);

					el.style.transform = `translate(${Math.cos(angle) * pull * 15}px, ${Math.sin(angle) * pull * 15}px)`;
					el.style.transition = "transform 0.1s ease-out";
				});

				el.addEventListener("mouseleave", () => {
					el.style.transform = "translate(0, 0)";
				});
			});

			// Parallax scroll effect for background layers
			window.addEventListener("scroll", () => {
				const scrolled = window.scrollY;
				document.querySelectorAll("[data-parallax]").forEach((el) => {
					const speed = parseFloat(el.dataset.parallax) || 0.5;
					el.style.transform = `translateY(${scrolled * speed}px)`;
				});
			});

			// Color scheme wipe on scroll to dark sections
			function checkColorScheme() {
				const scrolled = window.scrollY;
				const darkSections =
					document.querySelectorAll("[data-dark-mode]");

				darkSections.forEach((section) => {
					const rect = section.getBoundingClientRect();
					if (rect.top < window.innerHeight / 2 && rect.bottom > 0) {
						document.body.style.filter = "invert(0%)";
					}
				});
			}
			window.addEventListener("scroll", checkColorScheme);

			// Smooth page scroll snapping for horizontal sections
			document
				.querySelectorAll(".horizontal-scroll-section")
				.forEach((section) => {
					let isScrolling = false;

					section.addEventListener("wheel", (e) => {
						if (isScrolling) return;
						isScrolling = true;

						e.preventDefault();
						section.scrollLeft += e.deltaY;

						setTimeout(() => (isScrolling = false), 100);
					});
				});

			// SVG Path Morphing Animation
			document.querySelectorAll("[data-morph-svg]").forEach((svg) => {
				svg.classList.add("morph-shape");
			});

			// Infinite Kinetic Text Loops
			document.querySelectorAll(".kinetic-text").forEach((text) => {
				const clone = text.cloneNode(true);
				text.parentElement.appendChild(clone);
			});

			// Team member social icons toggle
			document.querySelectorAll(".team-member").forEach((member) => {
				member.addEventListener("click", function (e) {
					if (e.target.closest(".team-social")) return;

					const socialDiv = this.querySelector(".team-social");
					if (socialDiv) {
						socialDiv.classList.toggle("hidden");
						socialDiv.classList.toggle("show");
					}
				});
			});

			// Close social icons when clicking outside
			document.addEventListener("click", function (e) {
				if (!e.target.closest(".team-member")) {
					document
						.querySelectorAll(".team-social.show")
						.forEach((social) => {
							social.classList.remove("show");
							social.classList.add("hidden");
						});
				}
			});

		</script>
	</body>
</html>
